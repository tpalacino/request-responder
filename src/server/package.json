{
  "name": "@request-responder/server",
  "version": "1.0.0",
  "description": "A simple server that only serves static files from the 'public' folder.",
  "main": "server.js",
  "scripts": {
    "build": "tsc -b && cp -r ./public ./README.md ./dist && cp ./package.json.template ./dist/package.json && cd ./dist && zip -r ./server.zip ./*",
    "dev": "npm run build && node ./dist/server.js"
  },
  "license": "UNLICENSED",
  "type": "module",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.2"
  }
}
